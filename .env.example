# ============================================================
#  Variables de entorno del n8n-automation-kit (Windows)
#  Copia este archivo a  .env  y rellena tus valores reales.
#  El archivo .env NUNCA se sube a git (está en .gitignore).
# ============================================================

# --- REQUERIDO: conexión a tu instancia de n8n ---
# La URL debe terminar en "/"
N8N_API_URL=https://TU_N8N_URL/
# n8n -> Settings -> API -> Create API Key
N8N_API_KEY=TU_API_KEY

# --- OPCIONAL: Playwright (validación E2E con sesión de Chrome) ---
# Ruta a un perfil de Chrome DEDICADO (no el que usas a diario, para evitar bloqueos).
# Crea el perfil, inicia sesión en n8n/Coolify ahí, y apunta a esa carpeta.
CHROME_USER_DATA_DIR=C:\Users\joaqu\AppData\Local\Google\Chrome\PlaywrightProfile

# --- OPCIONAL: Coolify (solo si alojas n8n/microservicios en Coolify) ---
# COOLIFY_ACCESS_TOKEN=TU_TOKEN
# COOLIFY_BASE_URL=https://coolify.tudominio.com/

# --- OPCIONAL: Supabase ---
# SUPABASE_ACCESS_TOKEN=TU_TOKEN
# SUPABASE_PROJECT_REF=TU_PROJECT_REF
