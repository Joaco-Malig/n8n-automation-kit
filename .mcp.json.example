{
  "_comment_intro": "=== Plantilla de .mcp.json para WINDOWS — copia/edita y guarda como .mcp.json ===",
  "_comment_secrets": "Los secretos NO van aqui. Van en .env (o en variables de usuario de Windows con setx). Aqui solo se referencian con ${VAR}.",

  "mcpServers": {
    "_comment_required": "=== REQUERIDO — minimo para el kit ===",

    "n8n-mcp": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "n8n-mcp"],
      "env": {
        "N8N_API_URL": "${N8N_API_URL}",
        "N8N_API_KEY": "${N8N_API_KEY}",
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true"
      }
    },

    "_comment_playwright": "=== PLAYWRIGHT (opcional) — perfil de Chrome DEDICADO en Windows ===",
    "playwright": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "@playwright/mcp@latest",
        "--browser=chrome",
        "--user-data-dir=${CHROME_USER_DATA_DIR:-C:\\Users\\TU_USUARIO\\AppData\\Local\\Google\\Chrome\\PlaywrightProfile}"
      ]
    },

    "_comment_optional": "=== OPCIONALES — descomenta y agrega la var al .env si los usas ===",

    "coolify": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@masonator/coolify-mcp"],
      "env": {
        "COOLIFY_ACCESS_TOKEN": "${COOLIFY_ACCESS_TOKEN}",
        "COOLIFY_BASE_URL": "${COOLIFY_BASE_URL}"
      }
    },

    "supabase": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=${SUPABASE_PROJECT_REF}"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },

    "github": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
